# Environment Variables — Hardware Shop IMS Backend

# Server
NODE_ENV=development
PORT=5000


# JWT Secrets (use strong random strings in production — all must be DIFFERENT)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-long
JWT_RESET_SECRET=your-reset-secret-key-minimum-32-characters-long
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:5000

# Email (SMTP) - Optional for development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@hardwareshop.com

# App Settings
APP_NAME=Hardware Shop IMS
SESSION_TIMEOUT=1800000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5
